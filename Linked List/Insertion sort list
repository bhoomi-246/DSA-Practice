class Solution {
    public ListNode insertionSortList(ListNode head) {
        if(head==null){
            return head;
        }
        ListNode i=head;
        while(i!=null){
            ListNode j=i.next;
            while(j!=null){
                if(i.val>j.val){
                    int temp=i.val;
                    i.val=j.val;
                    j.val=temp;
                }
                j=j.next;
            }
            i=i.next;
        }
        return head;
    }
}
