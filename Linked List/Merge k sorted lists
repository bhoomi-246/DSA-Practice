class Solution {
    public ListNode mergeKLists(ListNode[] lists) {
        PriorityQueue<ListNode> pq = new PriorityQueue<>((a,b)->a.val-b.val);
        for(ListNode node:lists){
            if(node!=null){
                pq.offer(node);
            }
        }
        ListNode dummy=new ListNode(0);  //create ans list
        ListNode tail=dummy;
        while(!pq.isEmpty()){
            ListNode node=pq.poll();  //list se min node nikalo
            tail.next=node;           //ans me jodo
            tail=tail.next;

            if(node.next!=null){             //agar us list me abhi node bache h to heap me daal do
                pq.offer(node.next);
            }
        }
        return dummy.next; 
    }
}
