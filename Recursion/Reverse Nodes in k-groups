class Solution {
    public ListNode reverseKGroup(ListNode head, int k) {
        
        ListNode temp = head;
        int count = 0;
        
        while (temp != null && count < k) {
            temp = temp.next;
            count++;
        }
        
        if (count == k) {
            
            ListNode prev = null;
            ListNode curr = head;
            ListNode next = null;
            int i = 0;
            
            while (i < k && curr != null) {
                next = curr.next;
                curr.next = prev;
                prev = curr;
                curr = next;
                i++;
            }
            
            head.next = reverseKGroup(curr, k);
            
            return prev;
        }
        
        return head;
    }
}
