import java.util.Stack; 
class Solution {
    public void reorderList(ListNode head) {
        Stack<ListNode> st = new Stack<>();
        ListNode curr = head;
        while(curr!=null){
            st.push(curr);
            curr=curr.next;
        }
        int k=st.size()/2;
        curr=head;
        while(k-->0){
            ListNode topNode = st.peek();
            st.pop();
            ListNode temp=curr.next;
            curr.next=topNode;
            topNode.next=temp;
            curr=temp;
        }
        curr.next=null;
    }
}
