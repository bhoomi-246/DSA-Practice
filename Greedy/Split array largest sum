class Solution {
    public int splitArray(int[] nums, int k) {
        int max=0;
        int sum=0;
        for(int num:nums){
            max=Math.max(max,num);
            sum+=num;
        }
        int low=max,high=sum,ans=sum;
        while(low<=high){
            int mid=(low+high)/2;
            if(isPossiable(nums,k,mid)){
                ans=mid;
                high=mid-1;
            } else{
                low=mid+1;
            }
        }
        return ans;
    }
    private boolean isPossiable(int[]nums,int k,int mid){
        int count=1;
        int currSum=0;
        for(int num:nums){
            if(currSum+num<=mid){
                currSum+=num;
            } else{
                count++;
                currSum=num;
                if(count>k) return false;
            }
        }
        return true;
    }
}
