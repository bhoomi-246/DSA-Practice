class Solution {
    public List<List<Integer>> subsets(int[] nums) {
        List<List<Integer>> result = new ArrayList<>();
        backtrack(nums, 0, new ArrayList<>(), result);
        return result;
    }

    public void backtrack(int[] nums, int index, List<Integer> current, List<List<Integer>> result) {

        //BASE CASE is not needed kyuki yahan har state khud ek valid answer h  

         result.add(new ArrayList<>(current));  //yahan agar direct current result me store 
        //                                        karenge to agar baad me current chnage hoga to
        //                                        result bhi chnage ho jayega isliye current ki
        //                                        copy bana ke result me store karate h.
        for (int i = index; i < nums.length; i++) {
            current.add(nums[i]);
            backtrack(nums, i + 1, current, result);
            current.remove(current.size() - 1);
        }
    }
}
