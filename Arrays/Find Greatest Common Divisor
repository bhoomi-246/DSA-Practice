class Solution {
    public int findGCD(int[] nums) {
        int maxi=nums[0];
        int mini=nums[0];

        for(int num:nums){
            maxi=Math.max(maxi,num);
            mini=Math.min(mini,num);
        }
        int gcd=1;
        for (int i = 1; i <= mini; i++) {
            if (mini % i == 0 && maxi % i == 0) {
                gcd = i;
            }
        }
        return gcd;
    }
}
